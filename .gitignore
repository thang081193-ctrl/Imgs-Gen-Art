# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Data — ignore all direct children; negations below re-include committed ones.
# IMPORTANT: uses /data/* (not /data/), because gitignore cannot re-include
# descendants of a fully-ignored directory. /data/* ignores contents while
# keeping /data/ itself descendable for negations.
# Runtime-only (stays ignored): data/assets/, data/profile-assets/,
# data/keys.enc, data/profiles/ (seeded via npm run seed:profiles).
/data/*

# Static extracted data (Phase 2) — committed so fresh clones boot.
!/data/templates/

# Service accounts (never commit) — anchored: top-level keys/ only, do not match src/server/keys/
/keys/

# Local secrets (SA JSON, API keys, etc.) — never commit
/.secrets/

# SQLite DB
artforge.db
artforge.db-wal
artforge.db-shm
images-gen-art.db
images-gen-art.db-wal
images-gen-art.db-shm

# Vendored source apps for Phase 2 extraction — anchored to project root
/vendor/

# Env files
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code local settings (user-specific permissions + preview config)
.claude/settings.local.json
.claude/launch.json

# Logs
*.log
npm-debug.log*

# Test output
coverage/
.vitest-cache/
