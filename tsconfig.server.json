{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist/server",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "src/core/**/*.ts",
    "src/server/**/*.ts",
    "src/workflows/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "vendor", "src/client/**"]
}
