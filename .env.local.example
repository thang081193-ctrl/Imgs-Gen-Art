# Images Gen Art — local environment template
# Copy to .env.local and fill in. Never commit .env.local.
# All secrets are read server-side only; client fetches via /api/providers.

# Server binding (defaults shown)
# HOST=127.0.0.1
# PORT=5174

# Log level: debug | info | warn | error
# LOG_LEVEL=info

# Encryption KDF extra salt (optional, falls back to OS username + platform).
# KEY_KDF_SALT_EXTRA=

# Mock provider artificial latency (ms per generate call). Default 0 = instant.
# Integration tests run at 0 for speed. For manual browser cancel-tests
# (click Cancel mid-run), set to 1500 so a 10-asset batch runs ~15s.
# Invalid or negative values clamp to 0.
# MOCK_DELAY_MS=0
